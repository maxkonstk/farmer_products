APP_NAME="Фермерская лавка"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=database

LOG_CHANNEL=stderr
LOG_STDERR_FORMATTER=\Monolog\Formatter\JsonFormatter
LOG_LEVEL=info

DB_CONNECTION=pgsql
# Railway reference variable must use the exact name of your DB service, for example:
# DATABASE_URL=${{postgres.DATABASE_URL}}
DATABASE_URL=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=public

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SHOP_ORDER_PREFIX=FL
SHOP_NAVIGATION_CACHE_TTL=3600
SHOP_SUPPORT_EMAIL="support@example.com"
SHOP_ANALYTICS_PROVIDER=none
SHOP_GA4_MEASUREMENT_ID=
SHOP_GTM_CONTAINER_ID=
SHOP_ANALYTICS_WEB_VITALS=true
SHOP_ANALYTICS_DEBUG=false
SHOP_ANALYTICS_REQUIRE_CONSENT=true
SHOP_COOKIE_CONSENT_VERSION=2026-04

MIGRATION_ATTEMPTS=30
MIGRATION_DELAY_SECONDS=3
SEED_DEMO_DATA=false

QUEUE_WORKER_QUEUE=default
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_SLEEP=1
QUEUE_WORKER_TIMEOUT=90

VITE_APP_NAME="${APP_NAME}"
